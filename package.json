{
  "name": "chimeline",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/update-version.js && react-router build",
    "dev": "react-router dev --host 127.0.0.1",
    "setup:https": "mkdir -p .ssl && openssl req -x509 -newkey rsa:4096 -keyout .ssl/key.pem -out .ssl/cert.pem -days 365 -nodes -subj '/CN=localhost'",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc"
  },
  "dependencies": {
    "@react-router/fs-routes": "^7.13.1",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "^7.13.1",
    "html2pdf.js": "^0.14.0",
    "html5-qrcode": "^2.3.8",
    "isbot": "^5.1.31",
    "pdfmake": "^0.3.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/pdfmake": "^0.3.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
